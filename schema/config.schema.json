{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/feimingxliu/ub/internal/config/config",
  "$defs": {
    "ApprovalAgentConfig": {
      "properties": {
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "reasoning": {
          "$ref": "#/$defs/Config"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "CleanupConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "integer"
        },
        "sessions": {
          "$ref": "#/$defs/CleanupSessionsConfig"
        },
        "logs": {
          "$ref": "#/$defs/CleanupLogsConfig"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "CleanupLogsConfig": {
      "properties": {
        "max_size_mb": {
          "type": "integer"
        },
        "max_backups": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "CleanupSessionsConfig": {
      "properties": {
        "max_age": {
          "type": "integer"
        },
        "min_recent_per_workspace": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ContextConfig": {
      "properties": {
        "trigger_ratio": {
          "type": "number"
        },
        "keep_recent_turns": {
          "type": "integer"
        },
        "reserve_output_tokens": {
          "type": "integer"
        },
        "tool_results": {
          "$ref": "#/$defs/ContextToolResultConfig"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ContextToolResultConfig": {
      "properties": {
        "inline_max_bytes": {
          "type": "integer"
        },
        "inline_max_lines": {
          "type": "integer"
        },
        "spillover_enabled": {
          "type": "boolean"
        },
        "spillover_max_age": {
          "type": "integer"
        },
        "full_max_bytes": {
          "type": "integer"
        },
        "spillover_dir": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "HookSpec": {
      "properties": {
        "command": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "tools": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "timeout": {
          "type": "integer"
        },
        "on_failure": {
          "type": "string"
        },
        "env": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "HooksConfig": {
      "properties": {
        "pre_tool_call": {
          "items": {
            "$ref": "#/$defs/HookSpec"
          },
          "type": "array"
        },
        "post_tool_call": {
          "items": {
            "$ref": "#/$defs/HookSpec"
          },
          "type": "array"
        },
        "pre_user_turn": {
          "items": {
            "$ref": "#/$defs/HookSpec"
          },
          "type": "array"
        },
        "post_user_turn": {
          "items": {
            "$ref": "#/$defs/HookSpec"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "JobToolConfig": {
      "properties": {
        "max_concurrent": {
          "type": "integer"
        },
        "retention": {
          "type": "integer"
        },
        "cleanup_interval": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "LSPServerConfig": {
      "properties": {
        "command": {
          "type": "string"
        },
        "args": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "file_types": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "MCPServerConfig": {
      "properties": {
        "type": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "args": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "url": {
          "type": "string"
        },
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "MemoryAutoConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "trigger": {
          "type": "string",
          "enum": [
            "background",
            "immediate"
          ]
        },
        "max_candidates": {
          "type": "integer"
        },
        "max_prompt_chars": {
          "type": "integer"
        },
        "min_turns_since_extraction": {
          "type": "integer"
        },
        "min_new_messages": {
          "type": "integer"
        },
        "min_interval": {
          "type": "integer"
        },
        "drain_timeout": {
          "type": "integer"
        },
        "disable_on_external_context": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "MemoryConfig": {
      "properties": {
        "max_chars": {
          "type": "integer"
        },
        "auto": {
          "$ref": "#/$defs/MemoryAutoConfig"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ModelConfig": {
      "properties": {
        "supports_reasoning": {
          "type": "boolean"
        },
        "supported_efforts": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "default_effort": {
          "type": "string"
        },
        "max_context_tokens": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "PermissionConfig": {
      "properties": {
        "auto_allow_safe": {
          "type": "boolean"
        },
        "auto_allow_write": {
          "type": "boolean"
        },
        "auto_allow_exec": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ProfileConfig": {
      "properties": {
        "default_model": {
          "type": "string"
        },
        "default_provider": {
          "type": "string"
        },
        "small_model": {
          "type": "string"
        },
        "execution_mode": {
          "type": "string"
        },
        "max_turns": {
          "type": "integer"
        },
        "reasoning": {
          "$ref": "#/$defs/Config"
        },
        "prompt": {
          "$ref": "#/$defs/PromptConfig"
        },
        "approval_agent": {
          "$ref": "#/$defs/ApprovalAgentConfig"
        },
        "providers": {
          "additionalProperties": {
            "$ref": "#/$defs/ProviderConfig"
          },
          "type": "object"
        },
        "tools_disabled": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "tui": {
          "$ref": "#/$defs/TUIConfig"
        },
        "permissions": {
          "$ref": "#/$defs/PermissionConfig"
        },
        "mcp_servers": {
          "additionalProperties": {
            "$ref": "#/$defs/MCPServerConfig"
          },
          "type": "object"
        },
        "lsp_servers": {
          "additionalProperties": {
            "$ref": "#/$defs/LSPServerConfig"
          },
          "type": "object"
        },
        "tools": {
          "$ref": "#/$defs/ToolsConfig"
        },
        "context": {
          "$ref": "#/$defs/ContextConfig"
        },
        "cleanup": {
          "$ref": "#/$defs/CleanupConfig"
        },
        "memory": {
          "$ref": "#/$defs/MemoryConfig"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "PromptConfig": {
      "properties": {
        "workspace_instructions": {
          "$ref": "#/$defs/PromptSectionConfig"
        },
        "git_snapshot": {
          "$ref": "#/$defs/PromptSectionConfig"
        },
        "compact_style": {
          "type": "string",
          "enum": [
            "short",
            "structured"
          ]
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "PromptSectionConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "max_chars": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ProviderConfig": {
      "properties": {
        "type": {
          "type": "string"
        },
        "api_key": {
          "type": "string"
        },
        "base_url": {
          "type": "string"
        },
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "timeout": {
          "type": "integer"
        },
        "models": {
          "additionalProperties": {
            "$ref": "#/$defs/ModelConfig"
          },
          "type": "object"
        },
        "script": {
          "items": {
            "$ref": "#/$defs/ProviderScriptEvent"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ProviderScriptEvent": {
      "properties": {
        "type": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "reasoning": {
          "type": "string"
        },
        "tool_use_id": {
          "type": "string"
        },
        "tool_name": {
          "type": "string"
        },
        "input": true,
        "input_tokens": {
          "type": "integer"
        },
        "output_tokens": {
          "type": "integer"
        },
        "reasoning_tokens": {
          "type": "integer"
        },
        "cache_read_tokens": {
          "type": "integer"
        },
        "cache_write_tokens": {
          "type": "integer"
        },
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "TUIConfig": {
      "properties": {
        "theme": {
          "type": "string"
        },
        "compact": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ToolsConfig": {
      "properties": {
        "job": {
          "$ref": "#/$defs/JobToolConfig"
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  },
  "properties": {
    "default_model": {
      "type": "string"
    },
    "default_provider": {
      "type": "string"
    },
    "small_model": {
      "type": "string"
    },
    "execution_mode": {
      "type": "string"
    },
    "max_turns": {
      "type": "integer"
    },
    "reasoning": {
      "$ref": "#/$defs/Config"
    },
    "prompt": {
      "$ref": "#/$defs/PromptConfig"
    },
    "approval_agent": {
      "$ref": "#/$defs/ApprovalAgentConfig"
    },
    "providers": {
      "additionalProperties": {
        "$ref": "#/$defs/ProviderConfig"
      },
      "type": "object"
    },
    "profiles": {
      "additionalProperties": {
        "$ref": "#/$defs/ProfileConfig"
      },
      "type": "object"
    },
    "tools_disabled": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "tui": {
      "$ref": "#/$defs/TUIConfig"
    },
    "permissions": {
      "$ref": "#/$defs/PermissionConfig"
    },
    "mcp_servers": {
      "additionalProperties": {
        "$ref": "#/$defs/MCPServerConfig"
      },
      "type": "object"
    },
    "lsp_servers": {
      "additionalProperties": {
        "$ref": "#/$defs/LSPServerConfig"
      },
      "type": "object"
    },
    "tools": {
      "$ref": "#/$defs/ToolsConfig"
    },
    "context": {
      "$ref": "#/$defs/ContextConfig"
    },
    "cleanup": {
      "$ref": "#/$defs/CleanupConfig"
    },
    "hooks": {
      "$ref": "#/$defs/HooksConfig"
    },
    "memory": {
      "$ref": "#/$defs/MemoryConfig"
    }
  },
  "additionalProperties": false,
  "type": "object"
}
