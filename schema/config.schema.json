{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/feimingxliu/ub/internal/config/config",
  "$defs": {
    "ApprovalAgentConfig": {
      "properties": {
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "reasoning": {
          "$ref": "#/$defs/Config"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ContextConfig": {
      "properties": {
        "trigger_ratio": {
          "type": "number"
        },
        "keep_recent_turns": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "LSPServerConfig": {
      "properties": {
        "command": {
          "type": "string"
        },
        "args": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "file_types": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "MCPServerConfig": {
      "properties": {
        "type": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "args": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "url": {
          "type": "string"
        },
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ModelConfig": {
      "properties": {
        "supports_reasoning": {
          "type": "boolean"
        },
        "supported_efforts": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "default_effort": {
          "type": "string"
        },
        "max_context_tokens": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "PermissionConfig": {
      "properties": {
        "auto_allow_safe": {
          "type": "boolean"
        },
        "auto_allow_write": {
          "type": "boolean"
        },
        "auto_allow_exec": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ProfileConfig": {
      "properties": {
        "default_model": {
          "type": "string"
        },
        "default_provider": {
          "type": "string"
        },
        "small_model": {
          "type": "string"
        },
        "execution_mode": {
          "type": "string"
        },
        "reasoning": {
          "$ref": "#/$defs/Config"
        },
        "approval_agent": {
          "$ref": "#/$defs/ApprovalAgentConfig"
        },
        "providers": {
          "additionalProperties": {
            "$ref": "#/$defs/ProviderConfig"
          },
          "type": "object"
        },
        "tools_disabled": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "tui": {
          "$ref": "#/$defs/TUIConfig"
        },
        "permissions": {
          "$ref": "#/$defs/PermissionConfig"
        },
        "mcp_servers": {
          "additionalProperties": {
            "$ref": "#/$defs/MCPServerConfig"
          },
          "type": "object"
        },
        "lsp_servers": {
          "additionalProperties": {
            "$ref": "#/$defs/LSPServerConfig"
          },
          "type": "object"
        },
        "context": {
          "$ref": "#/$defs/ContextConfig"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ProviderConfig": {
      "properties": {
        "type": {
          "type": "string"
        },
        "api_key": {
          "type": "string"
        },
        "base_url": {
          "type": "string"
        },
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "timeout": {
          "type": "integer"
        },
        "models": {
          "additionalProperties": {
            "$ref": "#/$defs/ModelConfig"
          },
          "type": "object"
        },
        "script": {
          "items": {
            "$ref": "#/$defs/ProviderScriptEvent"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ProviderScriptEvent": {
      "properties": {
        "type": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "reasoning": {
          "type": "string"
        },
        "tool_use_id": {
          "type": "string"
        },
        "tool_name": {
          "type": "string"
        },
        "input": true,
        "input_tokens": {
          "type": "integer"
        },
        "output_tokens": {
          "type": "integer"
        },
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "TUIConfig": {
      "properties": {
        "theme": {
          "type": "string"
        },
        "compact": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  },
  "properties": {
    "default_model": {
      "type": "string"
    },
    "default_provider": {
      "type": "string"
    },
    "small_model": {
      "type": "string"
    },
    "execution_mode": {
      "type": "string"
    },
    "reasoning": {
      "$ref": "#/$defs/Config"
    },
    "approval_agent": {
      "$ref": "#/$defs/ApprovalAgentConfig"
    },
    "providers": {
      "additionalProperties": {
        "$ref": "#/$defs/ProviderConfig"
      },
      "type": "object"
    },
    "profiles": {
      "additionalProperties": {
        "$ref": "#/$defs/ProfileConfig"
      },
      "type": "object"
    },
    "tools_disabled": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "tui": {
      "$ref": "#/$defs/TUIConfig"
    },
    "permissions": {
      "$ref": "#/$defs/PermissionConfig"
    },
    "mcp_servers": {
      "additionalProperties": {
        "$ref": "#/$defs/MCPServerConfig"
      },
      "type": "object"
    },
    "lsp_servers": {
      "additionalProperties": {
        "$ref": "#/$defs/LSPServerConfig"
      },
      "type": "object"
    },
    "context": {
      "$ref": "#/$defs/ContextConfig"
    }
  },
  "additionalProperties": false,
  "type": "object"
}
